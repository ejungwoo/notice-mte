  free(data);

  // close file
  fclose(fp_adc);
  fclose(fp_tcb);

  // reset DAQ
  LTEreset(sid_lte);

  // close LTE
  LTEclose(sid_lte);
  
  // close DAQ
  CLOVERclose(sid);
  
  // close usb
  USB3Exit();
  
  return 0;
